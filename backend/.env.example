# OpenAI API key (required for /coach/chat and /generatePlan)
OPENAI_API_KEY=sk-...

# Optional: use OpenAI Agents workflow (sport → coach by category)
# Set to true or set OPENAI_WORKFLOW_ID to enable. When enabled, normal turns use
# the workflow; requestIntakeComplete still uses Chat Completions to return intake.
USE_AGENTS_WORKFLOW=true
OPENAI_WORKFLOW_ID=wf_xxxxxxxx

# Optional: model for workflow agents (default gpt-4o)
# OPENAI_COACH_MODEL=gpt-4o

# Optional: port (default 3001)
PORT=3001
